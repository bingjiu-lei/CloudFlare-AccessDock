{
  "name": "cloudflare-accessdock",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "node scripts/render-wrangler.mjs && wrangler deploy --keep-vars --config wrangler.generated.toml",
    "db:migrate:local": "wrangler d1 migrations apply ACCESSDOCK_DB --local",
    "db:migrate": "node scripts/render-wrangler.mjs && wrangler d1 migrations apply ACCESSDOCK_DB --remote --config wrangler.generated.toml"
  },
  "devDependencies": {
    "wrangler": "^4.20.0"
  }
}
